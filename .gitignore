# Dataset (large files - use Git LFS)
# data/raw/ is tracked via Git LFS (see .gitattributes)
data/processed/

# Python
__pycache__/
*.py[cod]
*.pyo
.env
venv/
.venv/
*.egg-info/
dist/
build/

# Jupyter (not used but just in case)
.ipynb_checkpoints/

# Outputs — keep metric summaries & figures tracked, exclude large regeneratable artifacts
outputs/results/*.joblib
outputs/results/*.parquet
outputs/results/*.log

# Node / React
frontend/node_modules/
frontend/.env
frontend/build/
frontend/dist/

# OS
.DS_Store
Thumbs.db
desktop.ini

# VS Code
.vscode/settings.json
